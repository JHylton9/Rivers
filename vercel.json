{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm --prefix react-example install",
  "buildCommand": "npm --prefix react-example run build",
  "outputDirectory": "react-example/dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
